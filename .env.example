# ============================================
# ELITOS FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# API URL (REQUIRED)
# ============================================
# Local development
VITE_API_URL=http://localhost:4000/api

# Production (update when deploying)
# VITE_API_URL=https://your-backend.vercel.app/api

# ============================================
# RAZORPAY (REQUIRED FOR PAYMENTS)
# ============================================
# Get from: https://dashboard.razorpay.com/app/keys
# Use the KEY ID (not secret) - this is public
VITE_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxx

# ============================================
# SITE URL
# ============================================
VITE_SITE_URL=http://localhost:3000

# Production
# VITE_SITE_URL=https://elitos.in

# ============================================
# SUPABASE (REQUIRED FOR GOOGLE AUTH)
# ============================================
# Get from: Supabase Dashboard > Settings > API
# Your project URL is already: https://whsjvigxahblmlvleiut.supabase.co
VITE_SUPABASE_URL=https://whsjvigxahblmlvleiut.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================
# Google Analytics 4
# Get from: https://analytics.google.com > Admin > Data Streams
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook)
# Get from: https://business.facebook.com/events_manager
VITE_META_PIXEL_ID=XXXXXXXXXXXXXXX
